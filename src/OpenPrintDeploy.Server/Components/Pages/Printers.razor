@page "/printers"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Data.Entities
@using OpenPrintDeploy.Server.Spooler
@inject PrinterService PrinterService
@inject RemovedPrinterService RemovedPrinterService
@inject IPrintSpoolerService Spooler

<PageTitle>Printers · Open Print Deploy</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Printers</h1>
    @if (!_showForm && !_importing)
    {
        <div>
            <button class="btn btn-outline-secondary me-2" @onclick="StartImportAsync">Import from spooler</button>
            <button class="btn btn-primary" @onclick="StartCreate">Add printer</button>
        </div>
    }
</div>

<div class="card mb-4 border-danger-subtle">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h5 class="card-title mb-1">Remove printers</h5>
                <p class="text-muted mb-0">
                    Every client removes these printer connections on its next sync, even if another tool installed them.
                </p>
            </div>
            @if (!_showRemoveForm)
            {
                <button class="btn btn-outline-danger" @onclick="StartRemovePrinter">Add removal</button>
            }
        </div>

        @if (_removeError is not null)
        {
            <div class="alert alert-danger" role="alert">@_removeError</div>
        }

        @if (_showRemoveForm)
        {
            <EditForm Model="_removeModel" OnValidSubmit="SaveRemovalAsync" class="mb-3">
                <DataAnnotationsValidator />
                <div class="input-group">
                    <InputText class="form-control" @bind-Value="_removeModel.UncPath"
                               placeholder="\\printsrv01\Retired-Queue" aria-label="Printer UNC path" />
                    <button type="submit" class="btn btn-danger" disabled="@_savingRemoval">Remove on clients</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelRemoval">Cancel</button>
                </div>
                <ValidationMessage For="() => _removeModel.UncPath" class="text-danger small" />
            </EditForm>
        }

        @if (_removedPrinters is null)
        {
            <p class="text-muted mb-0">Loading…</p>
        }
        else if (_removedPrinters.Count == 0)
        {
            <p class="text-muted mb-0">No printer removals configured.</p>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>UNC path</th><th class="text-end">Action</th></tr></thead>
                <tbody>
                    @foreach (var printer in _removedPrinters)
                    {
                        <tr>
                            <td><code>@printer.UncPath</code></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => StopRemovalAsync(printer.Id)">Stop removing</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (_importSummary is not null)
{
    <div class="alert alert-success" role="alert">@_importSummary</div>
}

@if (_importing)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Import from spooler</h5>
            <p class="form-text mt-0">
                Shared printers detected on this host. Tick the ones to add, edit
                their names and locations first if you like.
            </p>

            @if (_discoveryError is not null)
            {
                <div class="alert alert-warning">@_discoveryError</div>
            }

            @if (_discovered.Count == 0)
            {
                <p class="text-muted">Nothing to import.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th style="width: 2.5rem;"></th>
                            <th>Display name</th>
                            <th>UNC path</th>
                            <th>Driver</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _discovered)
                        {
                            <tr class="@(row.AlreadyImported ? "text-muted" : "")">
                                <td>
                                    <input class="form-check-input" type="checkbox"
                                           checked="@row.Selected"
                                           disabled="@row.AlreadyImported"
                                           @onchange="e => row.Selected = e.Value is true" />
                                </td>
                                <td>
                                    @if (row.AlreadyImported)
                                    {
                                        <div>@row.DisplayName</div>
                                        <span class="badge text-bg-secondary">already imported</span>
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" @bind="row.DisplayName" />
                                    }
                                </td>
                                <td><code>@row.Source.UncPath</code></td>
                                <td class="small text-muted">@(row.Source.Driver ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <button class="btn btn-primary" @onclick="ImportSelectedAsync"
                    disabled="@(_importBusy || !_discovered.Any(r => r.Selected && !r.AlreadyImported))">
                Import selected
            </button>
            <button class="btn btn-link" @onclick="CancelImport" disabled="@_importBusy">Cancel</button>
        </div>
    </div>
}

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@(_editingId is null ? "New printer" : "Edit printer")</h5>
            <EditForm Model="_model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">UNC path</label>
                    <InputText class="form-control" @bind-Value="_model.UncPath" placeholder="\\printsrv01\HR-MFP-01" />
                    <ValidationMessage For="() => _model.UncPath" class="text-danger small" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Display name</label>
                    <InputText class="form-control" @bind-Value="_model.DisplayName" placeholder="HR Multifunction (Floor 2)" />
                    <ValidationMessage For="() => _model.DisplayName" class="text-danger small" />
                </div>
                <button type="submit" class="btn btn-primary" disabled="@_saving">Save</button>
                <button type="button" class="btn btn-link" @onclick="CancelForm">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (_printers is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_printers.Count == 0)
{
    <p class="text-muted">No printers yet. Add one to get started.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Display name</th>
                <th>UNC path</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var printer in _printers)
            {
                <tr>
                    <td>@printer.DisplayName</td>
                    <td><code>@printer.UncPath</code></td>
                    <td class="text-end">
                        @if (_deletingId == printer.Id)
                        {
                            <span class="me-2 small">Delete?</span>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteAsync(printer.Id)">Yes</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _deletingId = null">No</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(printer)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => _deletingId = printer.Id">Delete</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<PrinterEntity>? _printers;
    private IReadOnlyList<RemovedPrinterEntity>? _removedPrinters;
    private PrinterInput _model = new();
    private Guid? _editingId;
    private Guid? _deletingId;
    private bool _showForm;
    private bool _saving;
    private string? _error;
    private RemovedPrinterInput _removeModel = new();
    private bool _showRemoveForm;
    private bool _savingRemoval;
    private string? _removeError;

    private bool _importing;
    private bool _importBusy;
    private string? _discoveryError;
    private string? _importSummary;
    private List<DiscoveredPrinterRow> _discovered = [];

    private sealed class DiscoveredPrinterRow
    {
        public required DiscoveredPrinter Source { get; init; }
        public bool Selected { get; set; }
        public bool AlreadyImported { get; init; }
        public string DisplayName { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _printers = await PrinterService.GetAllAsync();
        _removedPrinters = await RemovedPrinterService.GetAllAsync();
    }

    private void StartRemovePrinter()
    {
        _removeError = null;
        _removeModel = new RemovedPrinterInput();
        _showRemoveForm = true;
    }

    private void CancelRemoval()
    {
        _showRemoveForm = false;
        _removeError = null;
    }

    private async Task SaveRemovalAsync()
    {
        _savingRemoval = true;
        _removeError = null;
        try
        {
            await RemovedPrinterService.CreateAsync(_removeModel);
            _showRemoveForm = false;
            await ReloadAsync();
        }
        catch (AdminValidationException ex)
        {
            _removeError = ex.Message;
        }
        finally
        {
            _savingRemoval = false;
        }
    }

    private async Task StopRemovalAsync(Guid id)
    {
        await RemovedPrinterService.DeleteAsync(id);
        await ReloadAsync();
    }

    private void StartCreate()
    {
        _error = null;
        _editingId = null;
        _model = new PrinterInput();
        _showForm = true;
        CancelImport();
    }

    private async Task StartImportAsync()
    {
        _error = null;
        _showForm = false;
        _importing = true;
        _discoveryError = null;
        _importSummary = null;
        _discovered = [];

        var existing = new HashSet<string>(
            (_printers ?? []).Select(p => p.UncPath),
            StringComparer.OrdinalIgnoreCase);

        var found = await Spooler.GetSharedPrintersAsync();
        _discovered = found
            .Select(d => new DiscoveredPrinterRow
            {
                Source = d,
                AlreadyImported = existing.Contains(d.UncPath),
                Selected = !existing.Contains(d.UncPath),
                DisplayName = d.DisplayName,
            })
            .ToList();

        if (_discovered.Count == 0)
        {
            _discoveryError = OperatingSystem.IsWindows()
                ? "The local print spooler reported no shared printers. Add printers manually here."
                : "Spooler discovery only runs on Windows hosts. Add printers manually here.";
        }
    }

    private void CancelImport()
    {
        _importing = false;
        _discovered = [];
        _discoveryError = null;
    }

    private async Task ImportSelectedAsync()
    {
        _importBusy = true;
        _error = null;
        try
        {
            var toImport = _discovered.Where(r => r.Selected && !r.AlreadyImported).ToList();
            var errors = new List<string>();
            var imported = 0;
            foreach (var row in toImport)
            {
                var input = new PrinterInput
                {
                    UncPath = row.Source.UncPath,
                    DisplayName = string.IsNullOrWhiteSpace(row.DisplayName) ? row.Source.ShareName : row.DisplayName.Trim(),
                };
                try
                {
                    await PrinterService.CreateAsync(input);
                    imported++;
                }
                catch (AdminValidationException ex)
                {
                    errors.Add($"{row.Source.UncPath}: {ex.Message}");
                }
            }

            await ReloadAsync();
            _importSummary = errors.Count == 0
                ? $"Imported {imported} printer{(imported == 1 ? "" : "s")}."
                : $"Imported {imported} of {imported + errors.Count}. Skipped: {string.Join("; ", errors)}";
            CancelImport();
        }
        finally
        {
            _importBusy = false;
        }
    }

    private void StartEdit(PrinterEntity printer)
    {
        _error = null;
        _editingId = printer.Id;
        _model = new PrinterInput
        {
            UncPath = printer.UncPath,
            DisplayName = printer.DisplayName,
        };
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _error = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            if (_editingId is { } id)
            {
                await PrinterService.UpdateAsync(id, _model);
            }
            else
            {
                await PrinterService.CreateAsync(_model);
            }
            _showForm = false;
            await ReloadAsync();
        }
        catch (AdminValidationException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync(Guid id)
    {
        _error = null;
        try
        {
            await PrinterService.DeleteAsync(id);
            await ReloadAsync();
        }
        catch (AdminValidationException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _deletingId = null;
        }
    }
}
