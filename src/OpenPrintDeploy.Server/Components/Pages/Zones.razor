@page "/zones"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Data.Entities
@using OpenPrintDeploy.Server.Directory
@inject ZoneService ZoneService
@inject PrinterService PrinterService
@inject IDirectoryService Directory

<PageTitle>Zones · OpenPrintDeploy</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Zones</h1>
    @if (!_showForm)
    {
        <button class="btn btn-primary" @onclick="StartCreate">Add zone</button>
    }
</div>

@if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@(_editingId is null ? "New zone" : "Edit zone")</h5>
            <EditForm Model="_model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-sm-8 mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_model.Name" placeholder="HR" />
                        <ValidationMessage For="() => _model.Name" class="text-danger small" />
                    </div>
                    <div class="col-sm-4 mb-3">
                        <label class="form-label">Priority</label>
                        <InputNumber class="form-control" @bind-Value="_model.Priority" />
                        <div class="form-text">Sort order in this list — does not affect evaluation.</div>
                        <ValidationMessage For="() => _model.Priority" class="text-danger small" />
                    </div>
                </div>

                <fieldset class="mb-3">
                    <legend class="h6">Match rules</legend>
                    <p class="form-text mt-0">
                        A zone applies if the signed-in user is a member of <strong>any</strong> of
                        the listed groups. Start typing to pick a directory group by name (its SID is
                        stored), or paste a raw <code>S-1-5-21-…</code> SID for groups not in the
                        catalog.
                    </p>
                    <datalist id="opd-group-options">
                        @foreach (var group in _groups)
                        {
                            <option value="@group.Name"></option>
                        }
                    </datalist>
                    @for (var i = 0; i < _model.Rules.Count; i++)
                    {
                        var rule = _model.Rules[i];
                        var index = i;
                        <div class="row g-2 align-items-end mb-2">
                            <div class="col-md-11">
                                <label class="form-label small mb-0">Group</label>
                                <input class="form-control form-control-sm" list="opd-group-options"
                                       value="@rule.GroupName"
                                       @oninput="e => OnGroupInputAsync(rule, e)"
                                       placeholder="@_groupPlaceholder" />
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" title="Remove rule"
                                        @onclick="() => _model.Rules.RemoveAt(index)">✕</button>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _model.Rules.Add(new RuleInput())">
                        Add rule
                    </button>
                </fieldset>

                <fieldset class="mb-3">
                    <legend class="h6">Printers in this zone</legend>
                    @if (_allPrinters.Count == 0)
                    {
                        <p class="text-muted">No printers configured yet. Add printers first.</p>
                    }
                    else
                    {
                        @foreach (var printer in _allPrinters)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@($"printer-{printer.Id}")"
                                       checked="@_model.PrinterIds.Contains(printer.Id)"
                                       @onchange="e => TogglePrinter(printer.Id, e)" />
                                <label class="form-check-label" for="@($"printer-{printer.Id}")">
                                    @printer.DisplayName <code class="text-muted">@printer.UncPath</code>
                                </label>
                            </div>
                        }
                    }
                </fieldset>

                <button type="submit" class="btn btn-primary" disabled="@_saving">Save</button>
                <button type="button" class="btn btn-link" @onclick="CancelForm">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (_zones is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_zones.Count == 0)
{
    <p class="text-muted">No zones yet. Add one to start deploying printers.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Priority</th>
                <th>Groups</th>
                <th>Printers</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var zone in _zones)
            {
                <tr>
                    <td>@zone.Name</td>
                    <td>@zone.Priority</td>
                    <td>@DescribeGroups(zone)</td>
                    <td>@zone.Printers.Count</td>
                    <td class="text-end">
                        @if (_deletingId == zone.Id)
                        {
                            <span class="me-2 small">Delete?</span>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteAsync(zone.Id)">Yes</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _deletingId = null">No</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditAsync(zone.Id)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => _deletingId = zone.Id">Delete</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<ZoneEntity>? _zones;
    private IReadOnlyList<PrinterEntity> _allPrinters = [];
    private IReadOnlyList<DirectoryGroup> _groups = [];
    private readonly Dictionary<string, string> _nameToSid = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _sidToName = new(StringComparer.OrdinalIgnoreCase);
    private string _groupPlaceholder = "Start typing a group name…";
    private ZoneInput _model = new();
    private Guid? _editingId;
    private Guid? _deletingId;
    private bool _showForm;
    private bool _saving;
    private string? _error;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _zones = await ZoneService.GetAllAsync();
        _allPrinters = await PrinterService.GetAllAsync();
        await LoadGroupsAsync();
    }

    private const int GroupSearchLimit = 500;

    private async Task LoadGroupsAsync()
    {
        // Initial seed: a first slice for the empty datalist and to know whether
        // the directory is reachable at all. SearchGroupsAsync gets re-called
        // per-keystroke from OnGroupInputAsync to widen the catalog as the
        // admin types — large directories never fit in a single fetch.
        _groups = await Directory.SearchGroupsAsync(string.Empty, GroupSearchLimit);
        AccumulateGroups(_groups);
        _groupPlaceholder = _groups.Count > 0
            ? "Start typing a group name…"
            : "Paste a group SID (S-1-5-21-…)";
    }

    private void AccumulateGroups(IEnumerable<DirectoryGroup> groups)
    {
        foreach (var group in groups)
        {
            _nameToSid[group.Name] = group.Sid;
            _sidToName[group.Sid] = group.Name;
        }
    }

    private CancellationTokenSource? _groupSearchCts;

    /// <summary>
    /// Per-keystroke typeahead: replaces the datalist with whatever the
    /// directory returns for the typed substring, debounced ~250ms so we
    /// don't fire one LDAP query per character. Maps accumulate across
    /// searches so a name picked-then-replaced-by-another-search still
    /// resolves at save time.
    /// </summary>
    private async Task OnGroupInputAsync(RuleInput rule, ChangeEventArgs e)
    {
        var typed = e.Value?.ToString() ?? string.Empty;
        rule.GroupName = typed;

        _groupSearchCts?.Cancel();
        _groupSearchCts = new CancellationTokenSource();
        var token = _groupSearchCts.Token;

        try
        {
            await Task.Delay(250, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        IReadOnlyList<DirectoryGroup> results;
        try
        {
            results = await Directory.SearchGroupsAsync(typed.Trim(), GroupSearchLimit, token);
        }
        catch (OperationCanceledException)
        {
            // A new keystroke arrived; let that one's search be the winner.
            return;
        }
        if (token.IsCancellationRequested)
        {
            return;
        }

        _groups = results;
        AccumulateGroups(results);
        StateHasChanged();
    }

    private void StartCreate()
    {
        _error = null;
        _editingId = null;
        _model = new ZoneInput { Rules = { new RuleInput() } };
        _showForm = true;
    }

    private async Task StartEditAsync(Guid id)
    {
        _error = null;
        var zone = await ZoneService.GetAsync(id);
        if (zone is null)
        {
            _error = "That zone no longer exists.";
            await ReloadAsync();
            return;
        }

        _editingId = zone.Id;
        _model = new ZoneInput
        {
            Name = zone.Name,
            Priority = zone.Priority,
            PrinterIds = zone.Printers.Select(p => p.Id).ToList(),
            Rules = zone.Rules
                .Select(r => new RuleInput { GroupSid = r.GroupSid })
                .ToList(),
        };
        // Show each group rule by name; fall back to the raw SID if unresolvable.
        foreach (var rule in _model.Rules.Where(r => !string.IsNullOrWhiteSpace(r.GroupSid)))
        {
            rule.GroupName = _sidToName.GetValueOrDefault(rule.GroupSid!)
                ?? await Directory.ResolveGroupNameAsync(rule.GroupSid!)
                ?? rule.GroupSid;
        }
        if (_model.Rules.Count == 0)
        {
            _model.Rules.Add(new RuleInput());
        }
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _error = null;
    }

    private void TogglePrinter(Guid printerId, ChangeEventArgs e)
    {
        var isChecked = e.Value is true;
        if (isChecked)
        {
            if (!_model.PrinterIds.Contains(printerId))
            {
                _model.PrinterIds.Add(printerId);
            }
        }
        else
        {
            _model.PrinterIds.Remove(printerId);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            if (!await ResolveRuleGroupsAsync())
            {
                return;
            }

            if (_editingId is { } id)
            {
                await ZoneService.UpdateAsync(id, _model);
            }
            else
            {
                await ZoneService.CreateAsync(_model);
            }
            _showForm = false;
            await ReloadAsync();
        }
        catch (AdminValidationException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync(Guid id)
    {
        _error = null;
        try
        {
            await ZoneService.DeleteAsync(id);
            await ReloadAsync();
        }
        catch (AdminValidationException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _deletingId = null;
        }
    }

    /// <summary>
    /// Resolves each rule's typed <see cref="RuleInput.GroupName"/> to a stored
    /// SID (the directory is the source of truth). The local catalog map only
    /// contains groups the admin has seen via the typeahead in this session;
    /// if a typed name isn't there (e.g. selected earlier, then the suggestion
    /// list moved on), we re-query the directory rather than reject as typo.
    /// Returns false (with <see cref="_error"/> set) if a name truly doesn't
    /// resolve.
    /// </summary>
    private async Task<bool> ResolveRuleGroupsAsync()
    {
        foreach (var rule in _model.Rules)
        {
            var typed = rule.GroupName?.Trim();
            if (string.IsNullOrEmpty(typed))
            {
                rule.GroupSid = null;
                continue;
            }
            if (_nameToSid.TryGetValue(typed, out var sid))
            {
                rule.GroupSid = sid;
                continue;
            }
            if (typed.StartsWith("S-1-", StringComparison.OrdinalIgnoreCase))
            {
                rule.GroupSid = typed;
                continue;
            }

            // Last chance: ask the directory now. Catches the case where the
            // typeahead suggestion list was overwritten between selection and
            // save.
            var found = await Directory.SearchGroupsAsync(typed, limit: 5);
            var match = found.FirstOrDefault(g => string.Equals(g.Name, typed, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                AccumulateGroups([match]);
                rule.GroupSid = match.Sid;
                continue;
            }

            _error = $"Unknown group '{typed}'. Pick one from the list, or paste its SID (S-1-5-21-…).";
            return false;
        }

        return true;
    }

    private string DescribeGroups(ZoneEntity zone)
    {
        var names = zone.Rules
            .Where(r => !string.IsNullOrWhiteSpace(r.GroupSid))
            .Select(r => _sidToName.GetValueOrDefault(r.GroupSid!, r.GroupSid!))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        return names.Count == 0 ? "—" : string.Join(", ", names);
    }
}
