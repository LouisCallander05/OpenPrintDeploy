@page "/"
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using System.IO
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Download
@inject PrinterService Printers
@inject ZoneService Zones
@inject IConfiguration Config
@inject IWebHostEnvironment Env

<PageTitle>Open Print Deploy — Admin</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Centralised printer deployment, driven by zones.</p>

<div class="row g-3 mt-1" style="max-width: 640px;">
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_printerCount</h5>
                <p class="card-text text-muted mb-2">Printers configured</p>
                <a class="btn btn-sm btn-outline-primary" href="printers">Manage printers</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_zoneCount</h5>
                <p class="card-text text-muted mb-2">Zones defined</p>
                <a class="btn btn-sm btn-outline-primary" href="zones">Manage zones</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <h5 class="card-title">Client installer</h5>
        <p class="card-text text-muted mb-2">
            Both downloads are pre-named for this server and configure themselves
            from their own filename — no arguments needed.
        </p>

        <p class="card-text mb-1"><strong>For Intune (recommended)</strong> — an MSI. On upload,
            Intune auto-fills the install, uninstall, and detection. Wrap it as-is
            with the Win32 Content Prep tool.</p>
        <p class="card-text mb-2">Saves as <code>@_msiFileName</code></p>
        @if (_msiAvailable)
        {
            <a class="btn btn-sm btn-primary" href="download/client-msi">Download client MSI</a>
        }
        else
        {
            <span class="text-danger">
                MSI not bundled with this server build — publish with
                <code>scripts/Publish-Server.ps1</code> or set <code>Client:MsiPath</code>.
            </span>
        }

        <hr class="my-3" />

        <p class="card-text mb-1"><strong>Manual install</strong> — a self-extracting exe.
            Double-click on a workstation (UAC) and it installs + launches.</p>
        <p class="card-text mb-2">Saves as <code>@_installerFileName</code></p>
        @if (_installerAvailable)
        {
            <a class="btn btn-sm btn-outline-primary" href="download/client">Download installer (exe)</a>
        }
        else
        {
            <span class="text-danger">
                Exe not bundled with this server build — publish with
                <code>scripts/Publish-Server.ps1</code> or set <code>Client:InstallerPath</code>.
            </span>
        }
    </div>
</div>

@code {
    private int _printerCount;
    private int _zoneCount;
    private string _installerFileName = "";
    private bool _installerAvailable;
    private string _msiFileName = "";
    private bool _msiAvailable;

    protected override async Task OnInitializedAsync()
    {
        _printerCount = (await Printers.GetAllAsync()).Count;
        _zoneCount = (await Zones.GetAllAsync()).Count;

        _installerFileName = ClientInstallerDownload.DownloadFileName(Config);
        _installerAvailable = File.Exists(
            ClientInstallerDownload.ResolveInstallerPath(Config, Env.ContentRootPath));

        _msiFileName = ClientInstallerDownload.MsiDownloadFileName(Config);
        _msiAvailable = File.Exists(
            ClientInstallerDownload.ResolveMsiPath(Config, Env.ContentRootPath));
    }
}
