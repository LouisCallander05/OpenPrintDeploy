@page "/"
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using System.IO
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Download
@using OpenPrintDeploy.Server.Https
@inject PrinterService Printers
@inject ZoneService Zones
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@inject HttpsStatus HttpsState

<PageTitle>Open Print Deploy — Admin</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Centralised printer deployment, driven by zones.</p>

<div class="row g-3 mt-1" style="max-width: 640px;">
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_printerCount</h5>
                <p class="card-text text-muted mb-2">Printers configured</p>
                <a class="btn btn-sm btn-outline-primary" href="printers">Manage printers</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_zoneCount</h5>
                <p class="card-text text-muted mb-2">Zones defined</p>
                <a class="btn btn-sm btn-outline-primary" href="zones">Manage zones</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <h5 class="card-title">Client installer</h5>
        <p class="card-text text-muted mb-1">
            One self-extracting exe, pre-named for this server. Run it on a
            workstation (or wrap it for Intune) — no arguments needed; it
            configures itself from its own filename.
        </p>
        <p class="card-text mb-2">
            Saves as <code>@_installerFileName</code>
        </p>
        @if (_installerAvailable)
        {
            <a class="btn btn-sm btn-primary" href="download/client">Download client installer</a>
        }
        else
        {
            <span class="text-danger">
                Not bundled with this server build — publish with
                <code>scripts/Publish-Server.ps1</code> or set <code>Client:InstallerPath</code>.
            </span>
        }
    </div>
</div>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <h5 class="card-title">Connection security</h5>
        @if (HttpsState is { Enabled: true, Bound: true })
        {
            <p class="card-text text-success mb-1">
                HTTPS is enabled on port @HttpsState.Port (HTTPS for <code>@HttpsState.Host</code>).
            </p>
            @if (HttpsState.SelfSigned)
            {
                <p class="card-text text-muted mb-0">
                    Self-signed certificate <code>@HttpsState.Thumbprint</code>. Distribute its public
                    certificate to clients' Trusted Root store so they trust this server, then point
                    clients at <code>https://@(HttpsState.Host):@(HttpsState.Port)</code>.
                </p>
            }
            else
            {
                <p class="card-text text-muted mb-0">Certificate <code>@HttpsState.Thumbprint</code>.</p>
            }
        }
        else if (HttpsState.Enabled)
        {
            <p class="card-text text-danger mb-0">
                HTTPS is enabled but no certificate could be provisioned — the server is serving HTTP
                only. Check the service log, then restart.
            </p>
        }
        else
        {
            <p class="card-text text-warning mb-0">
                Traffic is <strong>HTTP only</strong>. Set <code>Https:Enabled</code> to <code>true</code>
                in <code>appsettings.json</code> and restart the service to serve over TLS.
            </p>
        }
    </div>
</div>

<UpdateCheckCard />

@code {
    private int _printerCount;
    private int _zoneCount;
    private string _installerFileName = "";
    private bool _installerAvailable;

    protected override async Task OnInitializedAsync()
    {
        _printerCount = (await Printers.GetAllAsync()).Count;
        _zoneCount = (await Zones.GetAllAsync()).Count;

        _installerFileName = ClientInstallerDownload.DownloadFileName(Config);
        _installerAvailable = File.Exists(
            ClientInstallerDownload.ResolveInstallerPath(Config, Env.ContentRootPath));
    }
}
