@page "/"
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using System.IO
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Download
@inject PrinterService Printers
@inject ZoneService Zones
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@inject OpenPrintDeploy.Server.Https.HttpsStatus HttpsState

<PageTitle>Open Print Deploy — Admin</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Centralised printer deployment, driven by zones.</p>

<div class="row g-3 mt-1" style="max-width: 640px;">
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_printerCount</h5>
                <p class="card-text text-muted mb-2">Printers configured</p>
                <a class="btn btn-sm btn-outline-primary" href="printers">Manage printers</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_zoneCount</h5>
                <p class="card-text text-muted mb-2">Zones defined</p>
                <a class="btn btn-sm btn-outline-primary" href="zones">Manage zones</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <h5 class="card-title">Client installer</h5>
        <p class="card-text text-muted mb-2">
            Pre-named for this server. Wrap as-is for Intune. Saves as <code>@_msiFileName</code>
        </p>
        @if (_msiAvailable)
        {
            <a class="btn btn-sm btn-primary" href="download/client-msi">Download client MSI</a>

            @if (HttpsState is { Enabled: true, Bound: true, SelfSigned: true, Thumbprint: not null })
            {
                <div class="alert alert-info mt-3 mb-0">
                    <p class="mb-1">
                        <strong>Manual install:</strong> download and run it as-is — the server and its
                        self-signed certificate ride in the filename (<code>@_msiFileName</code>), so it trusts
                        this server automatically.
                    </p>
                    <hr class="my-2" />
                    <p class="mb-1">
                        <strong>Intune / scripted:</strong> rename the file to a simple name
                        (e.g. <code>OpenPrintDeploy.Client.msi</code>) before wrapping with IntuneWinAppUtil,
                        and set the install command:
                    </p>
                    <pre class="mb-1"><code>msiexec /i "OpenPrintDeploy.Client.msi" SERVER="https://@(HttpsState.Host):@(HttpsState.Port)" CERTTHUMBPRINT="@HttpsState.Thumbprint" /quiet</code></pre>
                    <p class="mb-0 small text-muted">
                        The auto-pin filename can trip packaging tools, so rename + properties is the reliable
                        path for fleet deployment. A domain-CA certificate (<code>Https:PfxPath</code>) or
                        pushing the cert to clients’ Trusted Root removes the need for <code>CERTTHUMBPRINT</code>.
                    </p>
                </div>
            }
        }
        else
        {
            <span class="text-danger">
                MSI not bundled with this server build — publish with
                <code>scripts/Publish-Server.ps1</code> or set <code>Client:MsiPath</code>.
            </span>
        }
    </div>
</div>

@code {
    private int _printerCount;
    private int _zoneCount;
    private string _msiFileName = "";
    private bool _msiAvailable;

    protected override async Task OnInitializedAsync()
    {
        _printerCount = (await Printers.GetAllAsync()).Count;
        _zoneCount = (await Zones.GetAllAsync()).Count;

        var pin = HttpsState is { Enabled: true, Bound: true, SelfSigned: true } ? HttpsState.Thumbprint : null;
        _msiFileName = ClientInstallerDownload.MsiDownloadFileName(Config, pin);
        _msiAvailable = File.Exists(
            ClientInstallerDownload.ResolveMsiPath(Config, Env.ContentRootPath));
    }
}
