@page "/"
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using System.IO
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Download
@inject PrinterService Printers
@inject ZoneService Zones
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@inject OpenPrintDeploy.Server.Https.HttpsStatus HttpsState

<PageTitle>Open Print Deploy — Admin</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Centralised printer deployment, driven by zones.</p>

<div class="row g-3 mt-1" style="max-width: 640px;">
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_printerCount</h5>
                <p class="card-text text-muted mb-2">Printers configured</p>
                <a class="btn btn-sm btn-outline-primary" href="printers">Manage printers</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@_zoneCount</h5>
                <p class="card-text text-muted mb-2">Zones defined</p>
                <a class="btn btn-sm btn-outline-primary" href="zones">Manage zones</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <h5 class="card-title">Client installer</h5>
        @if (_msiAvailable)
        {
            <p class="card-text text-muted mb-2">
                Download, then rename to <code>OpenPrintDeploy.Client.msi</code> and wrap with IntuneWinAppUtil.
            </p>
            <a class="btn btn-sm btn-primary mb-3" href="download/client-msi">Download client MSI</a>

            <div class="mb-2">
                <div class="small text-muted mb-1">Install command</div>
                <pre class="border rounded bg-light p-2 mb-0"><code>@_installCommand</code></pre>
            </div>

            <div class="mb-2">
                <div class="small text-muted mb-1">Uninstall command</div>
                <pre class="border rounded bg-light p-2 mb-0"><code>msiexec /x "OpenPrintDeploy.Client.msi" /qn</code></pre>
            </div>

            <div class="mb-0">
                <div class="small text-muted mb-1">Detection rule — Registry</div>
                <pre class="border rounded bg-light p-2 mb-0"><code>Key:    HKLM\SOFTWARE\OpenPrintDeploy\Client
Value:  Version
Method: String — Equals — @_clientVersion</code></pre>
            </div>
        }
        else
        {
            <span class="text-danger">
                MSI not bundled with this server build — publish with
                <code>scripts/Publish-Server.ps1</code> or set <code>Client:MsiPath</code>.
            </span>
        }
    </div>
</div>

@code {
    private int _printerCount;
    private int _zoneCount;
    private bool _msiAvailable;
    private string _installCommand = "";
    private readonly string _clientVersion = BuildInfo.Version;

    protected override async Task OnInitializedAsync()
    {
        _printerCount = (await Printers.GetAllAsync()).Count;
        _zoneCount = (await Zones.GetAllAsync()).Count;

        _msiAvailable = File.Exists(
            ClientInstallerDownload.ResolveMsiPath(Config, Env.ContentRootPath));

        var host = HttpsState is { Enabled: true } && !string.IsNullOrWhiteSpace(HttpsState.Host)
            ? HttpsState.Host
            : ClientInstallerDownload.ResolveHost(Config);
        var port = HttpsState is { Enabled: true } ? HttpsState.Port : 5443;
        var server = $"https://{host}:{port}";

        // Pin the thumbprint only for a self-signed cert; a CA-issued cert clients
        // already trust needs none.
        var pin = HttpsState is { Bound: true, SelfSigned: true } ? HttpsState.Thumbprint : null;
        _installCommand = string.IsNullOrWhiteSpace(pin)
            ? $"msiexec /i \"OpenPrintDeploy.Client.msi\" SERVER=\"{server}\" /qn"
            : $"msiexec /i \"OpenPrintDeploy.Client.msi\" SERVER=\"{server}\" CERTTHUMBPRINT=\"{pin}\" /qn";
    }
}
