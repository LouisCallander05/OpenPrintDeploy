@page "/admin/directory"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using OpenPrintDeploy.Server.Admin
@using OpenPrintDeploy.Server.Directory
@inject IDirectoryService DirectoryService
@inject SyncDiagnosticsService Diagnostics

<PageTitle>Directory · Open Print Deploy</PageTitle>

<h1>Directory</h1>

<p class="text-muted" style="max-width: 48rem;">
    Health check for the directory the server is joined to.
</p>

<button class="btn btn-primary mb-3" @onclick="TestAsync" disabled="@_busy">
    @(_busy ? "Testing…" : "Test connection")
</button>

@if (_diag is { } d)
{
    <div class="card" style="max-width: 48rem;">
        <div class="card-body">
            <div class="@(d.Connected ? "text-success" : "text-danger") fw-semibold mb-2">
                @(d.Connected ? "✓ Connected" : "✗ Not connected")
            </div>

            <dl class="row mb-0">
                <dt class="col-sm-4">Provider</dt>
                <dd class="col-sm-8"><code>@d.Provider</code></dd>

                <dt class="col-sm-4">Auth mode</dt>
                <dd class="col-sm-8"><code>@d.AuthMode</code></dd>

                <dt class="col-sm-4">Server</dt>
                <dd class="col-sm-8">@(d.Server is null ? Em("(not resolved)") : Code(d.Server))</dd>

                <dt class="col-sm-4">Search base</dt>
                <dd class="col-sm-8">@(d.SearchBase is null ? Em("(not resolved)") : Code(d.SearchBase))</dd>

                <dt class="col-sm-4">Sample group count</dt>
                <dd class="col-sm-8">
                    @if (d.SampleGroupCount is { } n)
                    {
                        <span>@n returned by a probe query</span>
                    }
                    else
                    {
                        @Em("(not run)")
                    }
                </dd>

                @if (d.Error is { } err)
                {
                    <dt class="col-sm-4">Error</dt>
                    <dd class="col-sm-8"><code class="text-danger">@err</code></dd>
                }
            </dl>
        </div>
    </div>
}

<hr class="my-4" style="max-width: 48rem;" />

<h2 class="h4">Check a user</h2>
<p class="text-muted" style="max-width: 48rem;">
    See exactly what a sync resolves: the groups the user belongs to, the zones
    they match, and the printers that would deploy.
</p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CheckMeAsync" disabled="@_checking">
        @(_checking ? "Checking…" : "Check my access (from my sign-in)")
    </button>
    <div class="form-text" style="max-width: 48rem;">
        Uses your authenticated token. This is the reliable check.
    </div>
</div>

<div class="row g-2 align-items-end mb-1" style="max-width: 48rem;">
    <div class="col-sm-8">
        <label class="form-label">Or look up another user by name</label>
        <input class="form-control" @bind="_username" @bind:event="oninput"
               placeholder="DOMAIN\user or user@domain" />
    </div>
    <div class="col-sm-4">
        <button class="btn btn-outline-primary w-100" @onclick="CheckUserAsync"
                disabled="@(_checking || string.IsNullOrWhiteSpace(_username))">
            @(_checking ? "Checking…" : "Look up")
        </button>
    </div>
</div>
<p class="form-text mb-3" style="max-width: 48rem;">
    Include the domain prefix (e.g. <code>admin\jsmith</code>) to look up users
    from other trusted domains.
</p>

@if (_preview is { } p)
{
    <div class="card" style="max-width: 48rem;">
        <div class="card-body">
            <dl class="row mb-3">
                <dt class="col-sm-4">Account looked up</dt>
                <dd class="col-sm-8"><code>@p.NormalizedAccount</code></dd>

                <dt class="col-sm-4">Groups resolved</dt>
                <dd class="col-sm-8">@p.Groups.Count</dd>
            </dl>

            @if (p.Groups.Count == 0)
            {
                <div class="alert alert-warning mb-3">
                    <strong>No groups</strong> resolved for this account, so no zone can match.
                    If you used <em>name lookup</em>, the user may be in another trusted domain —
                    use <strong>Check my access</strong> while signed in as them instead. If this
                    is a name lookup of a same-domain user, the account couldn't be found under
                    the search base or LDAP is unreachable (run <strong>Test connection</strong>).
                </div>
            }
            else if (p.Printers.Count == 0)
            {
                <div class="alert alert-warning mb-3">
                    Groups resolved fine, but this user matches <strong>no zone</strong> — none of
                    their groups are on a zone rule, or the matched zones have no printers. Compare
                    the SIDs below with your zone rules.
                </div>
            }
            else
            {
                <div class="alert alert-success mb-3">
                    This user would receive <strong>@p.Printers.Count printer(s)</strong>.
                </div>
            }

            @if (p.Printers.Count > 0)
            {
                <h3 class="h6">Printers that would deploy</h3>
                <ul class="mb-3">
                    @foreach (var printer in p.Printers)
                    {
                        <li>@printer.DisplayName <code class="text-muted">@printer.UncPath</code></li>
                    }
                </ul>
            }

            @if (p.MatchedZones.Count > 0)
            {
                <h3 class="h6">Matched zones</h3>
                <ul class="mb-3">
                    @foreach (var zone in p.MatchedZones)
                    {
                        <li>@zone.Name <span class="text-muted small">(@zone.MatchedSids.Count rule(s) matched)</span></li>
                    }
                </ul>
            }

            <h3 class="h6">Resolved groups</h3>
            @if (p.Groups.Count == 0)
            {
                <p class="text-muted mb-0">(none)</p>
            }
            else
            {
                <ul class="mb-0" style="max-height: 16rem; overflow:auto;">
                    @foreach (var group in p.Groups)
                    {
                        <li>
                            @(group.Name ?? "(name unresolved)")
                            <code class="text-muted small">@group.Sid</code>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
}

@code {
    private DirectoryDiagnostics? _diag;
    private bool _busy;

    private string _username = "";
    private SyncDiagnostics? _preview;
    private bool _checking;
    private ClaimsPrincipal? _me;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Capture the signed-in admin so "Check my access" can diagnose from
        // their live token, and prefill the name box for convenience.
        if (AuthState is not null)
        {
            var state = await AuthState;
            _me = state.User;
            _username = state.User.Identity?.Name ?? "";
        }
    }

    private async Task CheckMeAsync()
    {
        if (_me is null)
        {
            return;
        }

        _checking = true;
        try
        {
            _preview = await Diagnostics.PreviewAsync(_me);
        }
        finally
        {
            _checking = false;
        }
    }

    private async Task CheckUserAsync()
    {
        if (string.IsNullOrWhiteSpace(_username))
        {
            return;
        }

        _checking = true;
        try
        {
            _preview = await Diagnostics.PreviewAsync(_username.Trim());
        }
        finally
        {
            _checking = false;
        }
    }

    private async Task TestAsync()
    {
        _busy = true;
        try
        {
            _diag = await DirectoryService.GetDiagnosticsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private static MarkupString Em(string text) => new($"<span class=\"text-muted\">{text}</span>");
    private static MarkupString Code(string text) => new($"<code>{System.Net.WebUtility.HtmlEncode(text)}</code>");
}
