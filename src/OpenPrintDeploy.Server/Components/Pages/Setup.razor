@page "/setup"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AuthPolicies.Admin)]
@using Microsoft.AspNetCore.Components.Authorization
@using OpenPrintDeploy.Server.Auth
@inject AdminAccessEvaluator Evaluator
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Set up · Open Print Deploy</PageTitle>

<h1>Welcome to Open Print Deploy</h1>

<div class="alert alert-warning" style="max-width: 720px;">
    <strong>No administrators are configured yet, so anyone who can sign in is currently an admin.</strong>
    Lock that down now by naming the directory group your IT admins belong to.
</div>

<div class="card mb-3" style="max-width: 720px;">
    <div class="card-body">
        <h5 class="card-title">Admin group</h5>
        <p class="text-muted">
            The group is checked against the directory before it’s accepted. Members of this group
            (across trusted domains) will be the administrators of Open Print Deploy.
        </p>

        @if (_groups.Count > 0)
        {
            <ul class="list-group mb-2">
                @foreach (var group in _groups)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@group</span>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveGroup(group)">Remove</button>
                    </li>
                }
            </ul>
        }

        <div class="input-group">
            <input class="form-control" placeholder="e.g. SchoolName Print Admins"
                   @bind="_newGroup" @bind:event="oninput" @onkeydown="OnGroupKeyDown" />
            <button class="btn btn-outline-primary" @onclick="AddGroupAsync" disabled="@_busy">Add group</button>
        </div>
        @if (_groupError is not null)
        {
            <div class="form-text text-danger">@_groupError</div>
        }
    </div>
</div>

<div class="card mb-3" style="max-width: 720px;">
    <div class="card-body">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="includeSelf" @bind="_includeSelf" />
            <label class="form-check-label" for="includeSelf">
                Also make my account (<code>@_currentUser</code>) an admin — a failsafe against locking yourself out.
            </label>
        </div>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger" style="max-width: 720px;">@_error</div>
}

<button class="btn btn-primary btn-lg" @onclick="FinishAsync" disabled="@_busy">
    @(_confirm ? "Finish anyway" : "Finish setup")
</button>

@code {
    private readonly List<string> _groups = [];
    private string? _newGroup;
    private string? _groupError;
    private string? _error;
    private string _currentUser = "(unknown)";
    private bool _includeSelf = true;
    private bool _busy;
    private bool _confirm;

    protected override async Task OnInitializedAsync()
    {
        // Onboarding is first-run only. Once admins are configured, this page
        // must not be a way to re-open access — send configured users home.
        if (!Evaluator.GetEffective().IsOpen)
        {
            Nav.NavigateTo("", forceLoad: false);
            return;
        }

        var state = await AuthState.GetAuthenticationStateAsync();
        _currentUser = state.User.Identity?.Name ?? "(unknown)";
    }

    private async Task AddGroupAsync()
    {
        _groupError = null;
        _error = null;
        var name = _newGroup?.Trim();
        if (string.IsNullOrEmpty(name))
        {
            return;
        }

        _busy = true;
        try
        {
            var sid = await Evaluator.ResolveGroupSidAsync(name);
            if (sid is null)
            {
                _groupError = $"No group named “{name}” was found in the directory.";
                return;
            }

            if (!_groups.Any(g => g.Equals(name, StringComparison.OrdinalIgnoreCase)))
            {
                _groups.Add(name);
            }

            _confirm = false;
            _newGroup = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnGroupKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = AddGroupAsync();
        }
    }

    private void RemoveGroup(string group)
    {
        _groups.RemoveAll(g => g.Equals(group, StringComparison.OrdinalIgnoreCase));
        _confirm = false;
    }

    private async Task FinishAsync()
    {
        _error = null;

        var users = new List<string>();
        if (_includeSelf && _currentUser is { Length: > 0 } && _currentUser != "(unknown)")
        {
            users.Add(_currentUser);
        }

        if (_groups.Count == 0 && users.Count == 0)
        {
            _error = "Add at least one admin group (or keep the failsafe ticked to add your own account).";
            return;
        }

        _busy = true;
        try
        {
            var prospective = new AdminAccess(_groups.ToList(), users);
            var effective = Evaluator.Combine(prospective);

            // Lock-out guard: unless they've already confirmed, warn if we can't
            // verify the current account would keep admin access (cross-domain
            // membership may not resolve). Second click applies anyway; the
            // appsettings break-glass is the ultimate recovery path.
            if (!_confirm && !await Evaluator.IsAdminAsync((await AuthState.GetAuthenticationStateAsync()).User, effective))
            {
                _confirm = true;
                _error = "Couldn’t confirm your own account is covered by these grants. Tick the failsafe "
                       + "above to add your username, or click “Finish anyway” to apply (you can recover via "
                       + "Auth:Admin in appsettings.json).";
                return;
            }

            Evaluator.SaveStored(prospective);
            Nav.NavigateTo("", forceLoad: true);
        }
        finally
        {
            _busy = false;
        }
    }
}
