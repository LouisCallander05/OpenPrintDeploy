@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using OpenPrintDeploy.Server.Auth
@inject AdminAccessEvaluator Evaluator
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted small">Signed in as @context.User.Identity?.Name</span>
                </Authorized>
                <NotAuthorized>
                    <span class="text-muted small">Open Print Deploy — Admin</span>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    // First-run gate: while no admin is configured (the system is open to any
    // signed-in user), force every admin page to the /setup onboarding so the
    // operator names an admin group before doing anything else. Once configured,
    // this never fires. /setup itself is exempt to avoid a redirect loop.
    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true || !Evaluator.GetEffective().IsOpen)
        {
            return;
        }

        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        if (!path.Equals("setup", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("setup");
        }
    }
}
