{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://*:5080",
  "Client": {
    "// InstallerPath": "Absolute or content-root-relative path to the tray installer the /download/client endpoint serves. Blank uses 'client/OpenPrintDeploy.Client.Installer.exe' next to the server exe (where Publish-Server.ps1 puts it).",
    "InstallerPath": ""
  },
  "Auth": {
    "Mode": "Negotiate",
    "Admin": {
      "GroupSids": []
    }
  },
  "Directory": {
    "Provider": "Ldap",
    "Ldap": {
      "AuthMode": "Negotiate",
      "Server": "",
      "Port": 389,
      "UseSsl": false,
      "SearchBase": "",
      "BindDn": "",
      "BindPassword": "",
      "TimeoutSeconds": 10,
      "AllowInvalidCertificate": false
    }
  }
}
