{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://*:5080",
  "Auth": {
    "Mode": "Negotiate",
    "Admin": {
      "GroupSids": []
    }
  },
  "Directory": {
    "Provider": "Ldap",
    "Ldap": {
      "AuthMode": "Negotiate",
      "Server": "",
      "Port": 389,
      "UseSsl": false,
      "SearchBase": "",
      "BindDn": "",
      "BindPassword": "",
      "TimeoutSeconds": 10,
      "AllowInvalidCertificate": false
    }
  }
}
