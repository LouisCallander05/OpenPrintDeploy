{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Mode": "Negotiate",
    "Admin": {
      "GroupSids": []
    }
  },
  "Directory": {
    "Provider": "Ldap",
    "Ldap": {
      "Server": "dc01.corp.local",
      "Port": 636,
      "UseSsl": true,
      "BindDn": "CN=svc-printdeploy,OU=Service Accounts,DC=corp,DC=local",
      "SearchBase": "DC=corp,DC=local",
      "TimeoutSeconds": 10,
      "AllowInvalidCertificate": false
    }
  }
}
