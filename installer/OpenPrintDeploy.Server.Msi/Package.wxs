<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-machine MSI for OpenPrintDeploy.Server.

  Replaces the old console-exe + PowerShell installers. msiexec is not subject
  to PowerShell script-block policies, so this keeps the EDR-friendliness that
  motivated the native exe while giving a real Add/Remove Programs entry,
  rollback, and clean major-upgrade handling.

  Built by scripts/Publish-Server.ps1, which harvests the self-contained
  win-x64 publish folder passed as $(var.HarvestDir). The service exe is
  authored explicitly (below) so it can own the ServiceInstall/ServiceControl
  and firewall rule; every other file is wildcard-harvested.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
      Name="Open Print Deploy Server"
      Manufacturer="OpenPrintDeploy"
      Version="$(var.ProductVersion)"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500"
      UpgradeCode="7E4D2A6C-1F3B-4C9E-9A2D-8B5F0C7E1A44">

    <!-- Block downgrades; allow same-version reinstall (repair). The fixed
         UpgradeCode above MUST never change or upgrades stop chaining. -->
    <MajorUpgrade
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of Open Print Deploy Server is already installed. Uninstall it first to install an older build." />

    <!-- Single self-contained .msi (cab embedded). -->
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPHELPLINK" Value="https://github.com/OpenPrintDeploy/OpenPrintDeploy" />
    <Icon Id="OpdServerIcon" SourceFile="..\..\src\OpenPrintDeploy.Client.Tray\Assets\appicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="OpdServerIcon" />

    <Feature Id="Main" Title="Open Print Deploy Server" Level="1">
      <ComponentGroupRef Id="ServerFiles" />
      <ComponentRef Id="ServerExe" />
      <ComponentRef Id="OpdIconFile" />
      <ComponentRef Id="AdminShortcut" />
      <ComponentRef Id="AdminDesktopShortcut" />
    </Feature>

    <!-- Install root: C:\Program Files\OpenPrintDeploy. The service's content
         root resolves here, so the bundled client MSI served at
         /download/client-msi is found relative to it. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenPrintDeploy" />
    </StandardDirectory>

    <!-- Start Menu folder for the admin-UI shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="OpenPrintDeploy" />
    </StandardDirectory>

    <!-- All-users desktop for the admin-UI shortcut (perMachine resolves this
         to the common desktop, so every operator on the box sees it). -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Everything in the publish folder EXCEPT the service exe (authored
         explicitly below). Subfolders, including client/, are preserved. -->
    <ComponentGroup Id="ServerFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.HarvestDir)\**">
        <Exclude Files="$(var.HarvestDir)\OpenPrintDeploy.Server.exe" />
      </Files>
    </ComponentGroup>

    <!-- The service exe: hosts the Windows service registration, failure
         recovery, and the inbound firewall rule on TCP 5443 (HTTPS). -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="ServerExe" Bitness="always64">
        <File Id="ServerExeFile"
              Source="$(var.HarvestDir)\OpenPrintDeploy.Server.exe"
              KeyPath="yes" />

        <ServiceInstall
            Id="OpenPrintDeployServerSvc"
            Name="OpenPrintDeployServer"
            DisplayName="Open Print Deploy Server"
            Description="Open Print Deploy admin server + /sync API for zone-driven printer deployment."
            Type="ownProcess"
            Start="auto"
            ErrorControl="normal"
            Account="LocalSystem"
            Vital="yes">
          <!-- Mirrors the old `sc failure`: restart after 60s twice, then give
               up; reset the failure counter once a day. -->
          <util:ServiceConfig
              FirstFailureActionType="restart"
              SecondFailureActionType="restart"
              ThirdFailureActionType="none"
              RestartServiceDelayInSeconds="60"
              ResetPeriodInDays="1" />
        </ServiceInstall>

        <!-- Start on install, stop on install/uninstall, remove on uninstall. -->
        <ServiceControl
            Id="OpenPrintDeployServerSvcControl"
            Name="OpenPrintDeployServer"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />

        <fw:FirewallException
            Id="OpenPrintDeployFw5443"
            Name="OpenPrintDeploy (5443/tcp)"
            Port="5443"
            Protocol="tcp"
            Scope="any" />
      </Component>
    </DirectoryRef>

    <!-- The OPD logo, installed alongside the server so the .url shortcuts can
         point their IconFile at a stable on-disk path. The shortcuts below are
         internet (.url) shortcuts, so they can't embed an icon — they reference
         this file. Same .ico the ARP entry uses (OpdServerIcon above). -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="OpdIconFile" Bitness="always64">
        <File Id="OpdIcoFile"
              Source="..\..\src\OpenPrintDeploy.Client.Tray\Assets\appicon.ico"
              Name="OpenPrintDeploy.ico"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcut to the admin UI. It's a .url internet shortcut
         (the target is a web address, not an exe). localhost is correct because
         the shortcut lives on the server itself, independent of hostname/DNS, and
         it's in the self-signed cert's SAN. The browser still warns until the
         self-signed root is trusted — expected on the server box itself.
         Start Menu folders count as a user-profile location, so the component
         keypath must be HKCU (per the documented WiX shortcut pattern / ICE38),
         even though the package itself is per-machine. -->
    <DirectoryRef Id="AppProgramMenuDir">
      <Component Id="AdminShortcut" Guid="9C2F7B30-5E84-4A1D-B6C2-3F0A9D4E7B12">
        <util:InternetShortcut
            Id="AdminUrlShortcut"
            Name="OpenPrintDeploy Admin"
            Target="https://localhost:5443/"
            IconFile="[INSTALLFOLDER]OpenPrintDeploy.ico"
            IconIndex="0"
            Type="url" />
        <RemoveFolder Id="RemoveAppProgramMenuDir" On="uninstall" />
        <RegistryValue
            Root="HKCU"
            Key="Software\OpenPrintDeploy"
            Name="AdminShortcutInstalled"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut to the admin UI. Same .url internet shortcut as the
         Start Menu one above, and same HKCU-keypath requirement: a non-advertised
         shortcut needs an HKCU registry keypath (ICE43) even though the package
         is per-machine. No RemoveFolder here — DesktopFolder is a standard
         directory we don't own, so we must not remove it. -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="AdminDesktopShortcut" Guid="B7A1E6D4-2C93-4F58-A0E1-6D5C8F2B9A37">
        <util:InternetShortcut
            Id="AdminUrlDesktopShortcut"
            Name="OpenPrintDeploy Admin"
            Target="https://localhost:5443/"
            IconFile="[INSTALLFOLDER]OpenPrintDeploy.ico"
            IconIndex="0"
            Type="url" />
        <RegistryValue
            Root="HKCU"
            Key="Software\OpenPrintDeploy"
            Name="AdminDesktopShortcutInstalled"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Minimal GUI on double-click (license + progress + finish); silent
         `msiexec /i ... /quiet` still works for Intune/scripted installs. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Open the admin UI right after an interactive install so the operator
         lands on the first-run setup page and names an admin group before
         anyone else can. A checkbox on the finish dialog (ticked by default)
         launches the URL as the installing user. Silent/Intune installs show no
         finish dialog, so nothing launches there (correct for headless ESP). -->
    <Property Id="WixShellExecTarget" Value="https://localhost:5443/" />
    <CustomAction Id="LaunchAdminUI"
        DllEntry="WixShellExec"
        BinaryRef="Wix4UtilCA_X64"
        Impersonate="yes"
        Execute="immediate"
        Return="ignore" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT"
        Value="Open the admin UI to finish setup (set an admin group)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchAdminUI"
          Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

  </Package>
</Wix>
