<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-machine MSI for the Open Print Deploy tray client.

  Built for Intune: because it's an MSI, uploading the .intunewin auto-fills the
  install command, uninstall command, and detection rule (the MSI product code).

  The server URL (and, for a self-signed server, the cert thumbprint to pin) is
  configured one of two ways:
    * msiexec properties (Intune / scripted — the reliable fleet path):
        msiexec /i "OpenPrintDeploy.Client.msi" SERVER="https://host:5443" CERTTHUMBPRINT="AB12…"
      Use any plain filename; do NOT rely on the auto-pin name for Intune, as
      IntuneWinAppUtil rejects special characters in filenames.
    * the MSI filename (manual double-click): the admin UI hands out
        "OpenPrintDeploy - host - AB12….msi"
      and the tray derives https://host:5443 AND the pinned thumbprint from it
      (TraySettings parses the recorded OriginalDatabase via Shared
      InstallerNaming). " - " separators (no glob chars) and a "(1)" duplicate-
      download suffix are both handled.

  An operator/CA-issued server cert clients already trust needs no thumbprint;
  pushing the self-signed public cert to Trusted Root (GPO/Intune) is the other
  trust option.

  After install it launches the tray in the signed-in user's session (via a
  post-install action that runs the tray with a launch-active-session flag as
  SYSTEM); with no one logged in (e.g. an Intune ESP install) it no-ops and the
  Run key starts the tray at next logon. A Start Menu shortcut allows a manual
  launch.

  Built by scripts/Publish-Client-Msi.ps1, which harvests the self-contained
  win-x64 tray publish folder passed as $(var.HarvestDir).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
      Name="Open Print Deploy Client"
      Manufacturer="OpenPrintDeploy"
      Version="$(var.ProductVersion)"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500"
      UpgradeCode="8F2C4A1E-6B3D-4F59-A0C7-1E9D2B5F8A40">

    <MajorUpgrade
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of Open Print Deploy Client is already installed. Uninstall it first to install an older build." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Logo shown in Add/Remove Programs (and the install UI). -->
    <Icon Id="OpdClientIcon" SourceFile="..\..\src\OpenPrintDeploy.Client.Tray\Assets\appicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="OpdClientIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/OpenPrintDeploy/OpenPrintDeploy" />

    <!-- Optional server URL. msiexec /i ... SERVER="https://host:5443". When blank,
         the tray derives the server from this MSI's filename. Public + Secure so
         it passes through to the deferred (system-context) install. -->
    <Property Id="SERVER" Secure="yes" />

    <!-- Optional server TLS certificate thumbprint to pin (the admin Settings page
         shows it for the self-signed cert). When set, the tray trusts exactly that
         cert without it being in the machine trust store. Leave blank for an
         operator/CA cert, or when the public cert is pushed to Trusted Root. -->
    <Property Id="CERTTHUMBPRINT" Secure="yes" />

    <!-- Optional allow-list of print-server hosts the tray may install printers
         from (comma-separated). Blank defaults to the configured server's host
         (the print server is usually the OPD server). Set this only when printers
         live on different print servers. -->
    <Property Id="ALLOWEDSERVERS" Secure="yes" />

    <Feature Id="Main" Title="Open Print Deploy Client" Level="1">
      <ComponentGroupRef Id="TrayFiles" />
      <ComponentRef Id="TrayExeComponent" />
      <ComponentRef Id="RemoveExeSettings" />
      <ComponentRef Id="ClientConfig" />
      <ComponentRef Id="AutoStartRunKey" />
      <ComponentRef Id="TrayShortcut" />
    </Feature>

    <!-- C:\Program Files\OpenPrintDeploy\Tray -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="OpdRootFolder" Name="OpenPrintDeploy">
        <Directory Id="INSTALLFOLDER" Name="Tray" />
      </Directory>
    </StandardDirectory>

    <!-- Start Menu folder for the manual-launch shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="OpenPrintDeploy" />
    </StandardDirectory>

    <!-- Terminate any running tray so its files aren't locked during an upgrade
         (each user session has its own tray.exe). No reboot prompt. -->
    <util:CloseApplication
        Id="CloseTray"
        Target="OpenPrintDeploy.Client.Tray.exe"
        TerminateProcess="0"
        RebootPrompt="no" />

    <!-- All tray files EXCEPT the exe, which is authored explicitly below so the
         post-install launch action and the shortcut can reference it by id. -->
    <ComponentGroup Id="TrayFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.HarvestDir)\**">
        <Exclude Files="$(var.HarvestDir)\OpenPrintDeploy.Client.Tray.exe" />
      </Files>
    </ComponentGroup>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="TrayExeComponent" Bitness="always64">
        <File Id="TrayExe" Source="$(var.HarvestDir)\OpenPrintDeploy.Client.Tray.exe" KeyPath="yes" />
      </Component>

      <!-- Remove any appsettings.json left by a previous EXE installer. The MSI
           configures the tray via the registry (below); a leftover appsettings.json
           shadows the registry in TraySettings' resolution order, so an EXE-to-MSI
           upgrade would silently keep the old (often http://) server URL. -->
      <Component Id="RemoveExeSettings" Bitness="always64" Guid="4A1C9E3B-7D5F-48A2-B0C6-8E2F1A5D9B73">
        <RemoveFile Id="RemoveOldAppSettings" Name="appsettings.json" On="install" Directory="INSTALLFOLDER" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="ExeSettingsCleaned" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Config the tray reads at startup: the explicit SERVER (if any), the
           certificate thumbprint to pin (if any), this MSI's own path (for the
           filename-derived server), and a version marker. -->
      <Component Id="ClientConfig" Bitness="always64">
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="Version" Type="string" Value="$(var.ProductVersion)" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="ServerBaseAddress" Type="string" Value="[SERVER]" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="ServerCertificateThumbprint" Type="string" Value="[CERTTHUMBPRINT]" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="AllowedPrintServers" Type="string" Value="[ALLOWEDSERVERS]" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\OpenPrintDeploy\Client"
                       Name="InstallerSource" Type="string" Value="[OriginalDatabase]" />
      </Component>

      <!-- Per-machine auto-start: the tray launches for every user at logon. Same
           Run value name as the EXE installer so the two never double-register. -->
      <Component Id="AutoStartRunKey" Bitness="always64">
        <RegistryValue Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                       Name="OpenPrintDeployTray" Type="string"
                       Value="&quot;[INSTALLFOLDER]OpenPrintDeploy.Client.Tray.exe&quot;" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcut for a manual launch. Start Menu is a per-user
         location, so the component keypath must be HKCU (WiX shortcut pattern /
         ICE38), even though the package is per-machine. -->
    <DirectoryRef Id="AppProgramMenuDir">
      <Component Id="TrayShortcut" Guid="D3A8F1C2-5B6E-4079-9C1A-2E4F6B8D0A55">
        <Shortcut Id="TrayStartMenuShortcut"
            Name="Open Print Deploy Client"
            Description="Sync your printers from the print server"
            Target="[#TrayExe]"
            WorkingDirectory="INSTALLFOLDER"
            Icon="OpdClientIcon" />
        <RemoveFolder Id="RemoveAppProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OpenPrintDeploy\Client"
                       Name="TrayShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Bring the tray up now, in the signed-in user's session. Deferred +
         Impersonate=no = runs as SYSTEM, so it can CreateProcessAsUser into the
         console session (the tray routes that launch flag to a session launcher).
         Fired
         after WriteRegistryValues so the spawned tray finds its server config,
         and asyncNoWait so a headless launch can never stall the install — a
         failure (or no one logged in) just means the Run key starts it at next
         logon. Skipped on uninstall (NOT REMOVE). -->
    <CustomAction Id="LaunchTraySession"
        FileRef="TrayExe"
        ExeCommand="--launch-active-session"
        Execute="deferred"
        Impersonate="no"
        Return="asyncNoWait" />

    <!-- On a true uninstall (NOT a major-upgrade removal), remove the per-user
         printer connections OPD created before the tray binaries go. Runs as
         SYSTEM and routes through the same session launcher to clean the console
         user's printers; runs BEFORE RemoveFiles so the exe still exists, and
         Return=ignore so a cleanup hiccup can never block the uninstall.
         Adopted (pre-existing) printers are left untouched by the tray. -->
    <CustomAction Id="CleanupTraySession"
        FileRef="TrayExe"
        ExeCommand="--cleanup-active-session"
        Execute="deferred"
        Impersonate="no"
        Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="LaunchTraySession" After="WriteRegistryValues" Condition="NOT REMOVE" />
      <Custom Action="CleanupTraySession" Before="RemoveFiles"
              Condition="(REMOVE=&quot;ALL&quot;) AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
